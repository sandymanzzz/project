# ─────────────────────────────────────────
# FORGE3D — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE ──
# Local MongoDB
MONGO_URI=mongodb+srv://sandy:sandy2007@forge3d.ivyuu27.mongodb.net/?appName=forge3d
# MongoDB Atlas (replace with your connection string)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/forge3d

# ── JWT ──
# Change this to a long, random secret string in production
JWT_SECRET=PtxdmZzknQd411EK2yhfOzowatfBSEvxH7JV1n1wcEA

# ── ADMIN CREDENTIALS (first-run seed) ──
ADMIN_EMAIL=admin@forge3d.com
ADMIN_PASSWORD=admin123

# ── URLS ──
# Backend public URL (used for Google OAuth redirect)
BACKEND_URL=http://localhost:5000
# Frontend URL (used for CORS and OAuth redirect back)
FRONTEND_URL=http://localhost:5000

# ── RAZORPAY ──
